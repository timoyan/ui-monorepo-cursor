{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": [
		"app.ts",
		"vite-env.d.ts",
		"app/**/*",
		"components/**/*",
		"core/**/*",
		"vite.config.ts",
		"panda.config.ts",
		"styled-system"
	],
	"exclude": ["node_modules", "vitest.config.ts"]
}

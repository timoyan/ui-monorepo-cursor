{
	"name": "pareto-pandacss-ark",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": ">=22.0.0 <23.0.0"
	},
	"scripts": {
		"prepare": "panda codegen",
		"dev": "concurrently \"pareto dev\" \"panda codegen --watch\"",
		"build": "panda codegen && NODE_ENV=production pareto build",
		"start": "NODE_ENV=production pareto start",
		"test": "vitest",
		"test:run": "vitest run",
		"lint:test": "! grep -rE 'toMatch(Inline)?Snapshot' --include='*.test.ts' --include='*.test.tsx' --exclude-dir=node_modules . 2>/dev/null"
	},
	"dependencies": {
		"@ark-ui/react": "^3.2.0",
		"@paretojs/core": "^5.0.0",
		"express": "^5.2.1",
		"graphql": "^16.12.0",
		"graphql-depth-limit": "^1.1.0",
		"graphql-yoga": "^5.17.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@pandacss/dev": "^0.52.0",
		"@testing-library/jest-dom": "^6.1.5",
		"@testing-library/react": "^14.1.2",
		"@testing-library/user-event": "^14.5.1",
		"@types/express": "^5.0.6",
		"@types/graphql-depth-limit": "^1.1.6",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.2.1",
		"concurrently": "^9.2.1",
		"happy-dom": "^20.0.0",
		"postcss": "^8.4.49",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	}
}
